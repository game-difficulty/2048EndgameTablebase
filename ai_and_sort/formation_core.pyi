class ClassicBookReader:
    def __init__(self, pattern_spec: PatternSpec, is_variant: bool = False) -> None: ...

    def move_on_dic(self, board: Sequence[Sequence[int]], path_list: Sequence[tuple[str, str]], pattern_full: str, nums_adjust: int) -> tuple[dict[str, float | str | None], str]: ...

    def get_random_state(self, path_list: Sequence[tuple[str, str]], pattern_full: str, spawn_rate4: float) -> int: ...

class AdvancedBookReader:
    def __init__(self, pattern_spec: AdvancedPatternSpec, is_variant: bool = False) -> None: ...

    def move_on_dic(self, board: Sequence[Sequence[int]], path_list: Sequence[tuple[str, str]], pattern_full: str, nums_adjust: int) -> tuple[dict[str, float | str | None], str]: ...

    def get_random_state(self, path_list: Sequence[tuple[str, str]], pattern_full: str, spawn_rate4: float) -> int: ...

class PatternLayer:
    def __init__(self) -> None: ...

    @property
    def size(self) -> int: ...

    @property
    def empty(self) -> bool: ...

    @property
    def dtype_name(self) -> str: ...

def get_build_progress() -> tuple[int, int]: ...

def reset_build_progress(total: int = 0) -> None: ...

def trie_compress_book(book_path: str, success_rate_dtype: str = "uint32") -> bool: ...

def trie_decompress_search(path_prefix: str, board: int, success_rate_dtype: str) -> float: ...

def find_classic_value(pathname: str, filename: str, search_key: int, success_rate_dtype: str = "uint32") -> float | None: ...

def apply_sym_like(board: int, symm_index: int) -> int: ...

def run_pattern_generate(arr_init: Annotated[NDArray[numpy.uint64], dict(shape=(None,), order='C', device='cpu', writable=False)], pattern_spec: PatternSpec, run_options: RunOptions) -> tuple[bool, PatternLayer, PatternLayer]: ...

def run_pattern_solve(d1: PatternLayer, d2: PatternLayer, pattern_spec: PatternSpec, run_options: RunOptions) -> None: ...

def run_pattern_build(arr_init: Annotated[NDArray[numpy.uint64], dict(shape=(None,), order='C', device='cpu', writable=False)], pattern_spec: PatternSpec, run_options: RunOptions) -> None: ...

def run_pattern_build_ad(arr_init: Annotated[NDArray[numpy.uint64], dict(shape=(None,), order='C', device='cpu', writable=False)], pattern_spec: AdvancedPatternSpec, run_options: RunOptions) -> None: ...
