from collections.abc import Sequence
import enum
from typing import Annotated

import numpy
from numpy.typing import NDArray


class SymmMode(enum.Enum):
    Identity = 0

    Full = 1

    Diagonal = 2

    Horizontal = 3

    Min33 = 4

    Min24 = 5

    Min34 = 6

class PatternSpec:
    def __init__(self) -> None: ...

    @property
    def name(self) -> str: ...

    @name.setter
    def name(self, arg: str, /) -> None: ...

    @property
    def pattern_masks(self) -> list[int]: ...

    @pattern_masks.setter
    def pattern_masks(self, arg: Sequence[int], /) -> None: ...

    @property
    def success_shifts(self) -> list[int]: ...

    @success_shifts.setter
    def success_shifts(self, arg: Sequence[int], /) -> None: ...

    @property
    def symm_mode(self) -> int: ...

    @symm_mode.setter
    def symm_mode(self, arg: int, /) -> None: ...

class RunOptions:
    def __init__(self) -> None: ...

    @property
    def target(self) -> int: ...

    @target.setter
    def target(self, arg: int, /) -> None: ...

    @property
    def steps(self) -> int: ...

    @steps.setter
    def steps(self, arg: int, /) -> None: ...

    @property
    def docheck_step(self) -> int: ...

    @docheck_step.setter
    def docheck_step(self, arg: int, /) -> None: ...

    @property
    def pathname(self) -> str: ...

    @pathname.setter
    def pathname(self, arg: str, /) -> None: ...

    @property
    def is_free(self) -> bool: ...

    @is_free.setter
    def is_free(self, arg: bool, /) -> None: ...

    @property
    def is_variant(self) -> bool: ...

    @is_variant.setter
    def is_variant(self, arg: bool, /) -> None: ...

    @property
    def spawn_rate4(self) -> float: ...

    @spawn_rate4.setter
    def spawn_rate4(self, arg: float, /) -> None: ...

    @property
    def success_rate_dtype(self) -> str: ...

    @success_rate_dtype.setter
    def success_rate_dtype(self, arg: str, /) -> None: ...

    @property
    def deletion_threshold(self) -> float: ...

    @deletion_threshold.setter
    def deletion_threshold(self, arg: float, /) -> None: ...

    @property
    def compress(self) -> bool: ...

    @compress.setter
    def compress(self, arg: bool, /) -> None: ...

    @property
    def compress_temp_files(self) -> bool: ...

    @compress_temp_files.setter
    def compress_temp_files(self, arg: bool, /) -> None: ...

    @property
    def optimal_branch_only(self) -> bool: ...

    @optimal_branch_only.setter
    def optimal_branch_only(self, arg: bool, /) -> None: ...

    @property
    def chunked_solve(self) -> bool: ...

    @chunked_solve.setter
    def chunked_solve(self, arg: bool, /) -> None: ...

    @property
    def num_threads(self) -> int: ...

    @num_threads.setter
    def num_threads(self, arg: int, /) -> None: ...

class AdvancedPatternSpec:
